# ----------------------------
# Backend model selection (choose ONLY ONE)
# ----------------------------
# OpenAI (preferred for general use)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (requires API key; only set if using Groq)
# GROQ_API_KEY=your_groq_api_key_here
# Optional: override default Groq endpoint
# GROQ_BASE_URL=https://api.groq.com

# Ollama (local model server; no API key)
# OLLAMA_BASE_URL=http://localhost:11434

# Custom OpenAI-compatible gateway (e.g., OpenRouter or proxy implementing OpenAI REST API)
# Set the base URL; if it requires a key, set CUSTOM_API_KEY as well.
# CUSTOM_API_URL=https://your-custom-openai-compatible-endpoint.example/v1
# CUSTOM_API_KEY=your_custom_gateway_key

# ----------------------------
# Search configuration
# ----------------------------
# SearXNG instance used for retrieval (default assumes local Docker/Compose on 8080)
SEARXNG_HOST=http://localhost:8080
# Restrict search to specific domains (comma-separated)
SEARXNG_ALLOWED_DOMAINS=radiopaedia.org

# ----------------------------
# Agent model selection / overrides
# ----------------------------
SUPERVISOR_MODEL=openai:gpt-4.1-mini
RESEARCHER_MODEL=openai:gpt-4.1-mini

# ----------------------------
# Notes
# ----------------------------
# • Only one backend (OpenAI, Groq, Ollama, or a custom OpenAI-compatible gateway) should be active at a time.
# • Custom gateways must expose an OpenAI-compatible API surface (model naming, function/tool calling, headers).
